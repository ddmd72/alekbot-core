# Alek-Core environment template. Copy to .env and fill in real values.
# .env is gitignored — NEVER commit real secrets. Placeholder values below are safe.

# ============================================================================
# Core runtime
# ============================================================================
APP_ENV=development                  # development | production | test
SLACK_MODE=socket                    # socket (local dev) | http (prod Events API)
DEBUG_PROMPTS=false                  # true → dump LLM request/response to GCS (dev)

# ============================================================================
# GCP / Firestore
# ============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=config/secrets/firebase-admin-key.json
FIRESTORE_DATABASE=us-production     # named DB; (default) is NOT used
GCS_MEDIA_BUCKET=your-media-bucket   # optional; enables file storage pipeline

# Cloud Run service URL (used by Makefile to build the OAuth redirect URI)
SERVICE_URL_DEV=https://your-service.run.app

# Dev identifiers for manual triggers / scripts (Makefile fallbacks)
USER_ID=
DEV_USER_ID=
DEV_ACCOUNT_ID=

# ============================================================================
# LLM providers (at least GEMINI_API_KEY required — default provider)
# ============================================================================
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# ============================================================================
# Slack
# ============================================================================
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=                     # Socket Mode app-level token (xapp-...)
SLACK_SIGNING_SECRET=               # HTTP mode only
DEV_SLACK_BOT_TOKEN=
DEV_SLACK_APP_TOKEN=

# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ============================================================================
# Auth (Firebase + OAuth) — see src/config/auth.py
# ============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
OAUTH_SESSION_SECRET=               # random 32+ char string (CSRF)
OAUTH_REDIRECT_URI=
DEFAULT_AUTH_PROVIDER=firebase

# ============================================================================
# Google integrations (Gmail indexing + Google Tasks + web search)
# ============================================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
GOOGLE_TASKS_OAUTH_REDIRECT_URI=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# ============================================================================
# Microsoft To Do (Tasks integration)
# ============================================================================
MICROSOFT_TODO_CLIENT_ID=
MICROSOFT_TODO_CLIENT_SECRET=
MICROSOFT_TODO_REDIRECT_URI=
MICROSOFT_TASKS_WEBHOOK_SECRET=

# ============================================================================
# Remote MCP server (experimental, dev-only)
# ============================================================================
# MCP_RESOURCE_URI=https://your-dev-service.run.app/mcp

# ============================================================================
# Optional features
# ============================================================================
UNSPLASH_ACCESS_KEY=                # HtmlPageGenerator image resolution (no-op if absent)
OPENAI_DEEP_RESEARCH_WEBHOOK_URL=
OPENAI_DEEP_RESEARCH_WEBHOOK_SECRET=
ENABLE_HTML_RENDERER=false
SYSTEM_DEFAULT_LANGUAGE=en          # uk | en | fr | es
